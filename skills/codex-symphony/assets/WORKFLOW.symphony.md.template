---
tracker:
  kind: linear
  api_key: $LINEAR_API_KEY
  project_slug: $LINEAR_PROJECT_SLUG
  active_states:
    - Todo
    - In Progress
  terminal_states:
    - Done
    - Canceled
    - Cancelled
    - Duplicate
polling:
  interval_ms: 5000
workspace:
  root: $SYMPHONY_WORKSPACE_ROOT
hooks:
  after_create: |
    git clone --no-hardlinks "$SYMPHONY_SOURCE_REPO_ROOT" .
    origin_url="$(git -C "$SYMPHONY_SOURCE_REPO_ROOT" remote get-url origin)"
    if [ -z "$origin_url" ] || printf '%s' "$origin_url" | grep -q '/.symphony/workspaces/'; then
      origin_url="$SOURCE_REPO_URL"
    fi
    git remote set-url origin "$origin_url"
    issue_id="$(basename "$PWD")"
    branch_name="$(printf '%s' "$issue_id" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9._/-' '-')"
    branch_name="symphony/${branch_name}"
    git fetch origin main || true
    if git show-ref --verify --quiet refs/remotes/origin/main; then
      git checkout -B "$branch_name" origin/main
    else
      git checkout -B "$branch_name"
    fi
    if [ -d "$SYMPHONY_SOURCE_REPO_ROOT/node_modules" ] && [ ! -e node_modules ]; then
      ln -s "$SYMPHONY_SOURCE_REPO_ROOT/node_modules" node_modules
    fi
  before_remove: |
    true
  timeout_ms: 180000
agent:
  max_concurrent_agents: 2
  max_turns: 20
codex:
  command: '"$CODEX_BIN" app-server --config shell_environment_policy.inherit=all --config model_reasoning_effort="high" --config model="gpt-5.3-codex"'
  approval_policy: never
  thread_sandbox: danger-full-access
  read_timeout_ms: 15000
  turn_sandbox_policy:
    type: dangerFullAccess
---

