#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/common.sh"

PORT="$(resolve_port)"
ENV_FILE="$(find_env_file || true)"
PID="$(read_pid_file)"

if is_pid_running "$PID"; then
  echo "Symphony is running (pid $PID)"
  print_runtime_summary
  if [[ -n "$ENV_FILE" ]]; then
    echo "Env file: $ENV_FILE"
  fi
  exit 0
fi

PROCESS_PID="$(symphony_process_pid)"
if [[ -n "$PROCESS_PID" ]]; then
  echo "Symphony is starting or running (pid $PROCESS_PID)"
  print_runtime_summary
  if [[ -n "$ENV_FILE" ]]; then
    echo "Env file: $ENV_FILE"
  fi
  exit 0
fi

if [[ -n "$PID" ]]; then
  echo "Stale pid file: $PID_FILE -> $PID"
fi

LISTEN_PID="$(port_pid)"
if [[ -n "$LISTEN_PID" ]]; then
  echo "Something is listening on port $PORT."
  echo "Dashboard: $(dashboard_url)"
  echo "PID file: $PID_FILE"
  exit 0
fi

if starting_recently; then
  echo "Symphony launch is in progress."
  echo "Dashboard warming up: $(dashboard_url)"
  echo "Logs: $OUT_FILE"
  if [[ -n "$ENV_FILE" ]]; then
    echo "Env file: $ENV_FILE"
  fi
  exit 0
fi

echo "Symphony is not running."
if [[ -n "$ENV_FILE" ]]; then
  echo "Env file: $ENV_FILE"
fi
echo "Start: $ROOT_DIR/scripts/symphony/start-background.sh"
exit 1
